# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ecc_platform"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-this"
AUTH_SECRET="your-auth-secret-here-change-this"

# Google OAuth (Optional - leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email - Resend (Optional - leave empty to disable)
RESEND_API_KEY=""
EMAIL_FROM="ECC Platform <notifications@eccplatform.com>"

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=""

# SMS - Twilio (Optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# WhatsApp - Twilio (Optional)
TWILIO_WHATSAPP_NUMBER=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron Secret (for scheduled scraping - used server-side only)
CRON_SECRET="your-cron-secret-here"

